<!DOCTYPE html>
<html lang="en">
<head>
  <!-- Google Tag Manager -->
    <script>(function(w,d,s,l,i){w[l]=w[l]||[];w[l].push({'gtm.start':
    new Date().getTime(),event:'gtm.js'});var f=d.getElementsByTagName(s)[0],
    j=d.createElement(s),dl=l!='dataLayer'?'&l='+l:'';j.async=true;j.src=
    'https://www.googletagmanager.com/gtm.js?id='+i+dl;f.parentNode.insertBefore(j,f);
    })(window,document,'script','dataLayer','GTM-NGTP6TW');</script>
    <!-- End Google Tag Manager -->

  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <link rel="icon" href="/assets/img/favicon.svg" type="image/svg+xml">

  <title>{{ seo.title or title or "Trust.med" }}</title>
  <meta
    name="description"
    content="{{ seo.description or 'Trust.med helps pharmaceutical trading partners simplify data exchange and network connectivity.' }}"
  />
  <link rel="canonical" href="https://trust.med{{ seo.canonical or page.url }}">

  <meta property="og:title" content="{{ seo.ogTitle or seo.title or title or 'Trust.med' }}">
  <meta
    property="og:description"
    content="{{ seo.ogDescription or seo.description or 'Trust.med helps pharmaceutical trading partners simplify data exchange and network connectivity.' }}"
  >
  <meta property="og:type" content="website">
  <meta property="og:url" content="https://trust.med{{ seo.canonical or page.url }}">
  <meta property="og:image" content="https://trust.med/assets/img/og-image.png">

  <meta name="twitter:card" content="summary_large_image">
  <meta name="twitter:title" content="{{ seo.ogTitle or seo.title or title or 'Trust.med' }}">
  <meta
    name="twitter:description"
    content="{{ seo.ogDescription or seo.description or 'Trust.med helps pharmaceutical trading partners simplify data exchange and network connectivity.' }}"
  >
  <meta name="twitter:image" content="https://trust.med/assets/img/og-image.png">

  <script type="application/ld+json">
  {
    "@context": "https://schema.org",
    "@type": "Organization",
    "name": "Trust.med",
    "url": "https://trust.med",
    "logo": "https://trust.med/assets/img/logo.png",
    "contactPoint": {
      "@type": "ContactPoint",
      "email": "support@trust.med",
      "contactType": "customer support"
    }
  }
  </script>

  {% if seoSchema %}
    {{ seoSchema | safe }}
  {% endif %}

  <!-- Shared CSS -->
  <link rel="stylesheet" href="/assets/css/shared.css">

  <!-- Page CSS -->
  {% if pageCss %}
  <link rel="stylesheet" href="{{ pageCss }}">
  {% endif %}
</head>

<body>

  <!-- Google Tag Manager (noscript) -->
  <noscript><iframe src="https://www.googletagmanager.com/ns.html?id=GTM-NGTP6TW"
  height="0" width="0" style="display:none;visibility:hidden"></iframe></noscript>
  <!-- End Google Tag Manager (noscript) -->

  {% include "partials/nav.njk" %}

  <main>
    {{ content | safe }}
  </main>

  {% include "partials/footer.njk" %}

  <!-- Shared JS -->
  <script src="/assets/js/shared.js"></script>

  <!-- Page JS -->
  {% if pageJs %}
  <script src="{{ pageJs }}"></script>
  {% endif %}

  {% include "partials/cal-scripts.njk" %}

</body>
</html>