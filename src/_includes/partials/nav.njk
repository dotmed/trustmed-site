<header class="tm-topbar" id="tmTopbar">
  <div class="tm-shell tm-topbar__inner">
      <a href="/" class="tm-brand" aria-label="Trust.med home">
        <svg
          class="tm-logo-mark"
          viewBox="0 0 220 40"
          xmlns="http://www.w3.org/2000/svg"
          role="img"
          aria-label="Trust.med"
        >
          <text
            x="0"
            y="28"
            font-family="Inter, Arial, Helvetica, sans-serif"
            font-size="26"
            font-weight="800"
            letter-spacing="-0.04em"
            fill="#111111"
          >
            Trust<tspan fill="#E4572E">.</tspan>med
          </text>
        </svg>
      </a>
          <button
            class="tm-menu-toggle"
            type="button"
            aria-expanded="false"
            aria-controls="tmMobileNav"
            aria-label="Open menu"
          >
            <span class="tm-menu-toggle__line"></span>
            <span class="tm-menu-toggle__line"></span>
            <span class="tm-menu-toggle__line"></span>
          </button>

      <nav class="tm-nav" id="tmMobileNav" aria-label="Primary">
        <a href="/" class="tm-nav__link{% if navKey == 'network' %} is-active{% endif %}">Network</a>
        <a href="/pricing/" class="tm-nav__link{% if navKey == 'pricing' %} is-active{% endif %}">Pricing</a>

        <a href="/find-a-partner/" class="tm-nav__link tm-nav__link--partner{% if navKey == 'find-a-partner' %} is-active{% endif %}">
          Find a Partner
      </a>

  <a
    href="https://dashboard.trust.med"
    class="tm-nav__link tm-nav__link--signin-mobile"
    aria-label="Sign in to dashboard"
    title="Sign in to Trust.med dashboard"
  >
    <svg class="tm-signin__icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" aria-hidden="true">
      <path stroke-width="2" stroke-linecap="round" stroke-linejoin="round"
        d="M15 3h4a2 2 0 0 1 2 2v14a2 2 0 0 1-2 2h-4"/>
      <path stroke-width="2" stroke-linecap="round" stroke-linejoin="round"
        d="M10 17l5-5-5-5"/>
      <path stroke-width="2" stroke-linecap="round" stroke-linejoin="round"
        d="M15 12H3"/>
    </svg>
    <span>Sign In</span>
  </a>
</nav>

    <div class="tm-topbar__actions">
      <a
        href="https://dashboard.trust.med"
        class="tm-signin"
        aria-label="Sign in to dashboard"
        title="Sign in to Trust.med dashboard"
      >
        <svg class="tm-signin__icon" viewBox="0 0 24 24" fill="none" stroke="currentColor">
          <path stroke-width="2" stroke-linecap="round" stroke-linejoin="round"
            d="M15 3h4a2 2 0 0 1 2 2v14a2 2 0 0 1-2 2h-4"/>
          <path stroke-width="2" stroke-linecap="round" stroke-linejoin="round"
            d="M10 17l5-5-5-5"/>
          <path stroke-width="2" stroke-linecap="round" stroke-linejoin="round"
            d="M15 12H3"/>
        </svg>
      </a>
    </div>
  </div>
</header>